# Telegram
BOT_TOKEN=your_bot_token_here
CONTACT_USERNAME=your_telegram_username

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Sheets CRM
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# Google Calendar — свободные слоты (расшарьте календарь на сервисный аккаунт)
GOOGLE_CALENDAR_ID=your@gmail.com
BOOKING_TIMEZONE=Europe/Moscow
BOOKING_WORK_START_HOUR=10
BOOKING_WORK_END_HOUR=18

# Закрытый канал (тестовая invite-ссылка)
CHANNEL_TEST_INVITE_LINK=https://t.me/+your_invite_link

# ЮMoney (физлицо)
# Кошелёк: ЮMoney → Настройки → Реквизиты (номер вида 41001...)
YOOMONEY_WALLET=
# Токен: https://yoomoney.ru/myservices/ → создать приложение
# Права: account-info, operation-history
YOOMONEY_TOKEN=

# Закрытый канал: @username или -100xxxxxxxxxx
# Бот — админ с правом «Приглашать пользователей»
CHANNEL_ID=

# Запасная ссылка (если API не сработал)
CHANNEL_INVITE_LINK=
